<file path="src/components/ContestsSystem.css">
.nx-contests-wrapper {
  width: 290px;
  height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  user-select: none;
  background: #08080a; /* Deep matte premium black */
  border-right: 1px solid rgba(255, 255, 255, 0.03);
  padding-left: 72px; /* Reserves space for NavDock exactly like Explorer/Judge */
  z-index: 10;
  position: relative;
  overflow: hidden;
}

/* Header with futuristic Outfit typography */
.nx-contests-header {
  height: 48px;
  min-height: 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18px 0 20px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.02);
}

.nx-contests-title {
  font-family: 'Outfit', sans-serif;
  font-size: 10.5px;
  font-weight: 400;
  letter-spacing: 0.22em;
  color: #ffffff;
  text-indent: 0.22em;
  text-transform: uppercase;
  opacity: 0.85;
}

/* Sync Button styling */
.nx-contests-sync-btn {
  background: transparent;
  border: none;
  color: rgba(255, 255, 255, 0.35);
  cursor: pointer;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  transition: all 0.2s ease;
}

.nx-contests-sync-btn:hover:not(:disabled) {
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
}

.nx-contests-sync-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.nx-sync-icon {
  width: 13px;
  height: 13px;
  transition: transform 0.5s ease;
}

.nx-contests-sync-btn.syncing .nx-sync-icon {
  animation: nx-spin 1s linear infinite;
}

/* Scroll Area for Contest sections */
.nx-contests-scroll-area {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  box-sizing: border-box;
}

.nx-contests-scroll-area::-webkit-scrollbar {
  width: 4px;
}
.nx-contests-scroll-area::-webkit-scrollbar-track {
  background: transparent;
}
.nx-contests-scroll-area::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 99px;
}
.nx-contests-scroll-area::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.15);
}

/* Loading/Status msg styles */
.nx-contests-status-msg {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 0;
  text-align: center;
  gap: 12px;
}

.nx-contests-status-msg p {
  font-family: 'Outfit', sans-serif;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.4);
  margin: 0;
}

.nx-contests-loader {
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255, 255, 255, 0.1);
  border-top-color: rgba(255, 255, 255, 0.7);
  border-radius: 50%;
  animation: nx-spin 0.8s linear infinite;
}

.nx-error-icon {
  width: 20px;
  height: 20px;
  color: #f87171;
}

.nx-retry-btn {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 4px;
  color: #ffffff;
  font-family: 'Outfit', sans-serif;
  font-size: 10px;
  padding: 4px 12px;
  cursor: pointer;
  transition: all 0.2s ease;
}

.nx-retry-btn:hover {
  background: #ffffff;
  color: #000000;
  border-color: #ffffff;
}

/* Section Header Styles */
.nx-contests-sections-stack {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.nx-contests-section {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.nx-contests-section-hdr {
  display: flex;
  align-items: center;
  gap: 8px;
  padding-left: 2px;
}

.nx-section-badge {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  display: inline-block;
}

.nx-section-badge.active {
  background: #ef4444;
  box-shadow: 0 0 8px #ef4444;
  animation: pulse-dot 1.5s infinite alternate;
}

.nx-section-badge.upcoming {
  background: #3b82f6;
  box-shadow: 0 0 8px #3b82f6;
}

.nx-section-badge.passed {
  background: rgba(255, 255, 255, 0.2);
}

.nx-section-title {
  font-family: 'Outfit', sans-serif;
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: rgba(255, 255, 255, 0.4);
}

/* Contest Card Styles */
.nx-contests-cards-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.nx-contest-card {
  display: flex;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.015);
  border: 1px solid rgba(255, 255, 255, 0.04);
  border-radius: 8px;
  padding: 12px;
  gap: 8px;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.nx-contest-card:hover {
  background: rgba(255, 255, 255, 0.035);
  border-color: rgba(255, 255, 255, 0.1);
  transform: translateY(-1px);
}

.nx-contest-card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nx-contest-id {
  font-family: ui-monospace, Consolas, monospace;
  font-size: 9px;
  color: rgba(255, 255, 255, 0.25);
}

.nx-contest-duration {
  font-family: 'Outfit', sans-serif;
  font-size: 9px;
  color: rgba(255, 255, 255, 0.4);
}

.nx-contest-name {
  font-family: 'Outfit', sans-serif;
  font-size: 11.5px;
  font-weight: 500;
  line-height: 1.4;
  color: rgba(255, 255, 255, 0.85);
  margin: 0;
}

.nx-contest-card:hover .nx-contest-name {
  color: #ffffff;
}

.nx-contest-status-line {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: 'Outfit', sans-serif;
  font-size: 8px;
  font-weight: 700;
  color: #ef4444;
  letter-spacing: 0.05em;
}

.nx-pulse-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #ef4444;
  animation: pulse-dot 1.2s infinite alternate;
}

.nx-contest-status-line.completed {
  color: rgba(255, 255, 255, 0.3);
  font-weight: 500;
}

