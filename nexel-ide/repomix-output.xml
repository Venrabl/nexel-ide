  "mo": {
    "prefix": "mo",
    "body": [
      "struct Mo {",
      "  int block;",
      "  struct Query { int l, r, idx; };",
      "  vector<Query> queries;",
      "  Mo(int n) { block = sqrt(n); }",
      "  void add_query(int l, int r, int idx) { queries.pb({l, r, idx}); }",
      "  void run(vector<ll> &ans) {",
      "    sort(all(queries), [&](const Query &a, const Query &b) {",
      "      if(a.l/block != b.l/block) return a.l < b.l;",
      "      return (a.l/block % 2) ? (a.r > b.r) : (a.r < b.r);",
      "    });",
      "    int L = 0, R = -1;",
      "    // current state",
      "    for(auto &q : queries) {",
      "      while(L > q.l) add(--L);",
      "      while(R < q.r) add(++R);",
      "      while(L < q.l) remove(L++);",
      "      while(R > q.r) remove(R--);",
      "      ans[q.idx] = /* current answer */;",
      "    }",
      "  }",
      "  void add(int pos) { }",
      "  void remove(int pos) { }",
      "};"
    ],
    "description": "Mo's algorithm skeleton"
  },
  "hld": {
    "prefix": "hld",
    "body": [
      "struct HLD {",
      "  vi parent, depth, heavy, head, pos;",
      "  int cur_pos;",
      "  HLD(const vvi &adj, int root) {",
      "    int n = sz(adj);",
      "    parent.resize(n);",
      "    depth.resize(n);",
      "    heavy.assign(n, -1);",
      "    head.resize(n);",
      "    pos.resize(n);",
      "    cur_pos = 0;",
      "    function<int(int,int)> dfs = [&](int u, int p) {",
      "      int sz = 1, max_sz = 0;",
      "      parent[u] = p;",
      "      for(int v : adj[u]) if(v != p) {",
      "        depth[v] = depth[u] + 1;",
      "        int sub = dfs(v, u);",
      "        sz += sub;",
      "        if(sub > max_sz) { max_sz = sub; heavy[u] = v; }",
      "      }",
      "      return sz;",
      "    };",
      "    dfs(root, -1);",
      "    function<void(int,int)> decompose = [&](int u, int h) {",
      "      head[u] = h;",
      "      pos[u] = cur_pos++;",
      "      if(heavy[u] != -1) decompose(heavy[u], h);",
      "      for(int v : adj[u]) if(v != parent[u] && v != heavy[u])",
      "        decompose(v, v);",
      "    };",
      "    decompose(root, root);",
      "  }",
      "  // path query stubs",
      "};"
    ],
    "description": "Heavy-Light Decomposition"
  },
  "centroid": {
    "prefix": "centroid",
