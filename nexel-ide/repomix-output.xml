      "  ll mid=l+(r-l)/2;",
      "  if(check(mid)){",
      "    ans=mid;",
      "    r=mid-1;",
      "  }else l=mid+1;",
      "}"
    ],
    "description": "binary search on answer"
  },

  "ternary_search": {
    "prefix": "ternary_search",
    "body": [
      "double l=0,r=1e6;",
      "for(int it=0;it<200;it++){",
      "  double m1=l+(r-l)/3;",
      "  double m2=r-(r-l)/3;",
      "  if(f(m1)<f(m2)) l=m1;",
      "  else r=m2;",
      "}"
    ],
    "description": "ternary search"
  },

  "lis": {
    "prefix": "lis",
    "body": [
      "vector<int> dp;",
      "for(auto x:a){",
      "  auto it=lower_bound(all(dp),x);",
      "  if(it==dp.end()) dp.pb(x);",
      "  else *it=x;",
      "}",
      "int len=dp.size();"
    ],
    "description": "longest increasing subsequence O(nlogn)"
  },

  "mex": {
    "prefix": "mex",
    "body": [
      "unordered_set<int> st(all(a));",
      "int mex=0;",
      "while(st.count(mex)) mex++;"
    ],
    "description": "minimum excluded value"
  },

  "kadane": {
    "prefix": "kadane",
    "body": [
      "ll best=-INF,cur=0;",
      "for(auto x:a){",
      "  cur=max(x,cur+x);",
      "  best=max(best,cur);",
      "}"
    ],
    "description": "maximum subarray sum"
  },

  "extgcd": {
    "prefix": "extgcd",
    "body": [
      "ll extgcd(ll a,ll b,ll &x,ll &y){",
      "  if(b==0){x=1;y=0;return a;}",
      "  ll x1,y1;",
      "  ll g=extgcd(b,a%b,x1,y1);",
      "  x=y1;",
      "  y=x1-y1*(a/b);",
      "  return g;",
      "}"
    ],
    "description": "extended euclidean algorithm"
  },

  "crt": {
    "prefix": "crt",
    "body": [
      "// Chinese Remainder Theorem skeleton"
    ],
    "description": "CRT template"
  },

  "bridge": {
    "prefix": "bridge",
    "body": [
      "vector<pair<int,int>> bridges;",
      "vector<int> tin(n,-1),low(n,-1);",
      "int timer=0;"
    ],
    "description": "bridge finding skeleton"
  },

  "articulation": {
    "prefix": "articulation",
    "body": [
      "vector<int> tin(n,-1),low(n,-1);",
      "vector<bool> isArt(n,false);"
    ],
    "description": "articulation points skeleton"
  },

  "euler_path": {
    "prefix": "euler_path",
    "body": [
      "vector<int> path;",
      "stack<int> st;",
      "st.push(start);"
    ],
    "description": "hierholzer euler path skeleton"
  },

  "tree_dp": {
    "prefix": "tree_dp",
    "body": [
      "vector<ll> dp(n);",
      "function<void(int,int)> dfs=[&](int u,int p){",
      "  dp[u]=1;",
      "  for(auto v:adj[u]) if(v!=p){",
      "    dfs(v,u);",
      "    dp[u]+=dp[v];",
      "  }",
      "};"
    ],
    "description": "tree dp skeleton"
  },

  "reroot_dp": {
    "prefix": "reroot_dp",
    "body": [
      "// rerooting dp skeleton"
    ],
    "description": "rerooting DP"
  },

  "knapsack01": {
    "prefix": "knapsack01",
    "body": [
      "vector<ll> dp(W+1,0);",
      "for(int i=0;i<n;i++){",
      "  for(int w=W;w>=wt[i];w--){",
      "    dp[w]=max(dp[w],dp[w-wt[i]]+val[i]);",
      "  }",
      "}"
    ],
    "description": "0/1 knapsack"
  },

  "sos_dp": {
    "prefix": "sos_dp",
    "body": [
      "for(int i=0;i<LOG;i++)",
      "  for(int mask=0;mask<(1<<LOG);mask++)",
      "    if(mask&(1<<i))",
      "      dp[mask]+=dp[mask^(1<<i)];"
    ],
    "description": "sum over subsets DP"
  },

  "interactive": {
    "prefix": "interactive",
    "body": [
      "cout << query << endl;",
      "cout.flush();"
    ],
    "description": "interactive problem output"
  },

  "stress": {
    "prefix": "stress",
    "body": [
      "while(true){",
      "  system(\"gen > input.txt\");",
      "  system(\"brute < input.txt > brute.txt\");",
      "  system(\"main < input.txt > main.txt\");",
      "  if(system(\"fc brute.txt main.txt\")) break;",
      "}"
    ],
    "description": "stress testing loop"
  },

  "chrono_timer": {
    "prefix": "chrono_timer",
    "body": [
      "auto start=chrono::high_resolution_clock::now();",
      "// code",
      "auto stop=chrono::high_resolution_clock::now();",
      "cerr<<chrono::duration_cast<chrono::milliseconds>(stop-start).count()<<\"ms\\n\";"
    ],
    "description": "execution timer"
  },

  "randll": {
    "prefix": "randll",
    "body": [
      "mt19937_64 rng(chrono::steady_clock::now().time_since_epoch().count());",
      "ll x=uniform_int_distribution<ll>(l,r)(rng);"
    ],
    "description": "random long long"
  },

  "caseprint": {
    "prefix": "caseprint",
    "body": [
      "cout << \"Case #\" << tc << \": \" << ans << '\\n';"
    ],
    "description": "google kickstart style output"
  }
}
