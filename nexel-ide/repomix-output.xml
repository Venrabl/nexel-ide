    "body": [
      "struct SegTree {",
      "  int n;",
      "  vll tree;",
      "  SegTree(int n) : n(n), tree(2*n) {}",
      "  void build() {",
      "    for(int i = n-1; i > 0; --i)",
      "      tree[i] = tree[i<<1] + tree[i<<1|1];",
      "  }",
      "  void update(int p, ll val) {",
      "    for(tree[p += n] = val; p > 1; p >>= 1)",
      "      tree[p>>1] = tree[p] + tree[p^1];",
      "  }",
      "  ll query(int l, int r) {",
      "    ll res = 0;",
      "    for(l += n, r += n+1; l < r; l >>= 1, r >>= 1) {",
      "      if(l&1) res += tree[l++];",
      "      if(r&1) res += tree[--r];",
      "    }",
      "    return res;",
      "  }",
      "};"
    ],
    "description": "Segment Tree (point update, range sum)"
  },
  "lazy_segtree": {
    "prefix": "lazy_segtree",
    "body": [
      "struct LazySegTree {",
      "  int n;",
      "  vll tree, lazy;",
      "  LazySegTree(int n) : n(n), tree(4*n), lazy(4*n) {}",
      "  void push(int v, int tl, int tr) {",
      "    if(lazy[v]) {",
      "      int tm = (tl+tr)/2;",
      "      tree[v*2] += lazy[v] * (tm-tl+1);",
      "      lazy[v*2] += lazy[v];",
      "      tree[v*2+1] += lazy[v] * (tr-tm);",
      "      lazy[v*2+1] += lazy[v];",
      "      lazy[v] = 0;",
      "    }",
      "  }",
      "  void update(int v, int tl, int tr, int l, int r, ll add) {",
      "    if(l > r) return;",
      "    if(l == tl && r == tr) {",
      "      tree[v] += add * (r-l+1);",
      "      lazy[v] += add;",
      "      return;",
      "    }",
      "    push(v, tl, tr);",
      "    int tm = (tl+tr)/2;",
      "    update(v*2, tl, tm, l, min(r,tm), add);",
      "    update(v*2+1, tm+1, tr, max(l,tm+1), r, add);",
      "    tree[v] = tree[v*2] + tree[v*2+1];",
      "  }",
      "  ll query(int v, int tl, int tr, int l, int r) {",
      "    if(l > r) return 0;",
      "    if(l == tl && r == tr) return tree[v];",
      "    push(v, tl, tr);",
      "    int tm = (tl+tr)/2;",
      "    return query(v*2, tl, tm, l, min(r,tm)) +",
      "           query(v*2+1, tm+1, tr, max(l,tm+1), r);",
      "  }",
      "};"
    ],
    "description": "Lazy Segment Tree (range add, range sum)"
  },
