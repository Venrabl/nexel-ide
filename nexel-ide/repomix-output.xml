      "int timer = 0, scc_cnt = 0;",
      "void dfs(int u) {",
      "  idx[u] = lowlink[u] = timer++;",
      "  st.push(u);",
      "  onstack[u] = true;",
      "  for(int v : adj[u]) {",
      "    if(idx[v] == -1) {",
      "      dfs(v);",
      "      lowlink[u] = min(lowlink[u], lowlink[v]);",
      "    } else if(onstack[v]) {",
      "      lowlink[u] = min(lowlink[u], idx[v]);",
      "    }",
      "  }",
      "  if(lowlink[u] == idx[u]) {",
      "    while(true) {",
      "      int w = st.top(); st.pop();",
      "      onstack[w] = false;",
      "      comp[w] = scc_cnt;",
      "      if(w == u) break;",
      "    }",
      "    ++scc_cnt;",
      "  }",
      "}",
      "void find_scc() {",
      "  idx.assign(n, -1);",
      "  lowlink.assign(n, -1);",
      "  comp.assign(n, -1);",
