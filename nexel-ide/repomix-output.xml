      "struct CentroidDecomp {",
      "  vvi adj;",
      "  vb dead;",
      "  vi sz;",
      "  CentroidDecomp(const vvi &g) : adj(g), dead(sz(g)), sz(sz(g)) {}",
      "  int get_size(int u, int p) {",
      "    sz[u] = 1;",
      "    for(int v : adj[u]) if(v != p && !dead[v])",
      "      sz[u] += get_size(v, u);",
      "    return sz[u];",
      "  }",
      "  int get_centroid(int u, int p, int n) {",
      "    for(int v : adj[u]) if(v != p && !dead[v] && sz[v] > n/2)",
      "      return get_centroid(v, u, n);",
      "    return u;",
      "  }",
      "  void decompose(int u) {",
      "    int n = get_size(u, -1);",
      "    int c = get_centroid(u, -1, n);",
      "    dead[c] = true;",
      "    // process centroid c",
      "    for(int v : adj[c]) if(!dead[v]) decompose(v);",
      "  }",
      "};"
    ],
    "description": "Centroid decomposition"
  },
  "matrix_exp": {
