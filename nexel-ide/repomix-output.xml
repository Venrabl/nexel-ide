  "fft": {
    "prefix": "fft",
    "body": [
      "using cd = complex<double>;",
      "const double PI = acos(-1);",
      "void fft(vector<cd> &a, bool invert) {",
      "  int n = sz(a);",
      "  for(int i=1, j=0; i<n; ++i) {",
      "    int bit = n>>1;",
      "    for(; j&bit; bit>>=1) j ^= bit;",
      "    j ^= bit;",
      "    if(i < j) swap(a[i], a[j]);",
      "  }",
      "  for(int len=2; len<=n; len<<=1) {",
      "    double ang = 2*PI/len * (invert ? -1 : 1);",
      "    cd wlen(cos(ang), sin(ang));",
      "    for(int i=0; i<n; i+=len) {",
      "      cd w(1);",
      "      for(int j=0; j<len/2; ++j) {",
      "        cd u = a[i+j], v = a[i+j+len/2] * w;",
      "        a[i+j] = u + v;",
      "        a[i+j+len/2] = u - v;",
      "        w *= wlen;",
      "      }",
      "    }",
      "  }",
      "  if(invert) for(auto &x : a) x /= n;",
      "}"
    ],
    "description": "Fast Fourier Transform"
  },
  "ntt": {
    "prefix": "ntt",
    "body": [
      "const ll MOD = 998244353, ROOT = 3;",
      "void ntt(vll &a, bool invert) {",
      "  int n = sz(a);",
      "  for(int i=1, j=0; i<n; ++i) {",
      "    int bit = n>>1;",
      "    for(; j&bit; bit>>=1) j ^= bit;",
      "    j ^= bit;",
      "    if(i < j) swap(a[i], a[j]);",
      "  }",
      "  for(int len=2; len<=n; len<<=1) {",
      "    ll wlen = modpow(ROOT, (MOD-1)/len, MOD);",
      "    if(invert) wlen = modinv(wlen, MOD);",
      "    for(int i=0; i<n; i+=len) {",
      "      ll w = 1;",
      "      for(int j=0; j<len/2; ++j) {",
      "        ll u = a[i+j], v = a[i+j+len/2] * w % MOD;",
      "        a[i+j] = (u+v) % MOD;",
      "        a[i+j+len/2] = (u-v+MOD) % MOD;",
      "        w = w * wlen % MOD;",
      "      }",
      "    }",
      "  }",
      "  if(invert) {",
      "    ll inv_n = modinv(n, MOD);",
      "    for(auto &x : a) x = x * inv_n % MOD;",
      "  }",
      "}"
    ],
    "description": "Number Theoretic Transform"
  },
