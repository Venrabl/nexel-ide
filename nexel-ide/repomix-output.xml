    "body": [
      "struct RollingHash {",
      "  ll mod, p;",
      "  vector<ll> h, pw;",
      "  RollingHash(const string &s, ll mod=1e9+7, ll p=31) : mod(mod), p(p) {",
      "    int n = sz(s);",
      "    h.resize(n+1);",
      "    pw.resize(n+1, 1);",
      "    for(int i=0; i<n; ++i) {",
      "      h[i+1] = (h[i]*p + s[i]) % mod;",
      "      pw[i+1] = pw[i]*p % mod;",
      "    }",
      "  }",
      "  ll hash(int l, int r) {",
      "    return (h[r+1] - h[l]*pw[r-l+1] % mod + mod) % mod;",
      "  }",
