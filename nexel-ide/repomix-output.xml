  "dsu": {
    "prefix": "dsu",
    "body": [
      "struct DSU {",
      "  vi parent, rank;",
      "  DSU(int n) : parent(n), rank(n,0) {",
      "    iota(all(parent), 0);",
      "  }",
      "  int find(int x) {",
      "    return parent[x] == x ? x : parent[x] = find(parent[x]);",
      "  }",
      "  bool unite(int x, int y) {",
      "    x = find(x);",
      "    y = find(y);",
      "    if(x == y) return false;",
      "    if(rank[x] < rank[y]) swap(x,y);",
      "    parent[y] = x;",
      "    if(rank[x] == rank[y]) ++rank[x];",
      "    return true;",
      "  }",
      "};"
    ],
    "description": "Disjoint Set Union (Union-Find)"
  },
