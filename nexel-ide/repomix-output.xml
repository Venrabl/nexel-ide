  height: 100vh;
  background: rgba(4, 4, 6, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 11000;
  animation: modal-fade-in 0.25s cubic-bezier(0.16, 1, 0.3, 1);
