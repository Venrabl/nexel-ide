      "struct Matrix {",
      "  vvll mat;",
      "  int n;",
      "  Matrix(int n) : n(n), mat(n, vll(n)) {}",
      "  Matrix operator*(const Matrix &other) const {",
      "    Matrix res(n);",
      "    for(int i=0; i<n; ++i)",
      "      for(int k=0; k<n; ++k)",
      "        for(int j=0; j<n; ++j)",
      "          res.mat[i][j] = (res.mat[i][j] + mat[i][k]*other.mat[k][j]) % MOD;",
      "    return res;",
      "  }",
      "  Matrix power(ll e) const {",
      "    Matrix res(n), b = *this;",
      "    for(int i=0; i<n; ++i) res.mat[i][i] = 1;",
      "    while(e) {",
      "      if(e&1) res = res * b;",
      "      b = b * b;",
      "      e >>= 1;",
      "    }",
      "    return res;",
      "  }",
      "};"
    ],
    "description": "Matrix exponentiation"
