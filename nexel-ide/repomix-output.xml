  "lca_bl": {
    "prefix": "lca_bl",
    "body": [
      "struct LCA {",
      "  int n, LOG;",
      "  vvi up;",
      "  vi depth;",
      "  LCA(const vvi &adj, int root) {",
      "    n = sz(adj);",
      "    LOG = 32 - __builtin_clz(n);",
      "    up.assign(LOG, vi(n, -1));",
      "    depth.resize(n);",
      "    function<void(int,int)> dfs = [&](int u, int p) {",
      "      up[0][u] = p;",
      "      for(int v : adj[u]) if(v != p) {",
      "        depth[v] = depth[u] + 1;",
      "        dfs(v, u);",
      "      }",
      "    };",
      "    dfs(root, -1);",
      "    for(int j=1; j<LOG; ++j)",
      "      for(int i=0; i<n; ++i)",
      "        if(up[j-1][i] != -1)",
      "          up[j][i] = up[j-1][up[j-1][i]];",
      "  }",
      "  int lift(int u, int d) {",
      "    for(int j=0; j<LOG; ++j)",
      "      if(d>>j & 1) u = up[j][u];",
      "    return u;",
      "  }",
      "  int lca(int u, int v) {",
      "    if(depth[u] < depth[v]) swap(u,v);",
      "    u = lift(u, depth[u]-depth[v]);",
      "    if(u == v) return u;",
      "    for(int j=LOG-1; j>=0; --j) {",
      "      if(up[j][u] != up[j][v]) {",
      "        u = up[j][u];",
      "        v = up[j][v];",
      "      }",
      "    }",
      "    return up[0][u];",
      "  }",
      "};"
    ],
    "description": "LCA using binary lifting"
  },
