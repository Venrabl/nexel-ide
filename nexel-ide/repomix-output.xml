      "vector<Point> convex_hull(vector<Point> pts) {",
      "  sort(all(pts), [](Point a, Point b) { return tie(a.x,a.y) < tie(b.x,b.y); });",
      "  vector<Point> hull;",
      "  for(int step=0; step<2; ++step) {",
      "    auto start = sz(hull);",
      "    for(auto p : pts) {",
      "      while(sz(hull)-start >= 2 && cross(hull[sz(hull)-2], hull.back(), p) <= 0)",
      "        hull.pop_back();",
      "      hull.pb(p);",
      "    }",
      "    hull.pop_back();",
      "    reverse(all(pts));",
      "  }",
      "  return hull;",
      "}"
    ],
