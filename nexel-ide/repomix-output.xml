      "struct SparseTable {",
      "  vvi st;",
      "  vi log;",
      "  SparseTable(const vi &a) {",
      "    int n = sz(a);",
      "    log.resize(n+1);",
      "    for(int i=2; i<=n; ++i) log[i] = log[i/2]+1;",
      "    int K = log[n]+1;",
      "    st.assign(K, vi(n));",
      "    st[0] = a;",
      "    for(int j=1; j<K; ++j) {",
      "      for(int i=0; i+(1<<j)<=n; ++i) {",
      "        st[j][i] = min(st[j-1][i], st[j-1][i+(1<<(j-1))]);",
      "      }",
      "    }",
      "  }",
      "  int query(int l, int r) {",
      "    int j = log[r-l+1];",
      "    return min(st[j][l], st[j][r-(1<<j)+1]);",
      "  }",
      "};"
    ],
    "description": "Sparse Table for RMQ"
