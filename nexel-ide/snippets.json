  "dijkstra": {
    "prefix": "dijkstra",
    "body": [
      "vll dist(n, INF);",
      "priority_queue<pll, vector<pll>, greater<pll>> pq;",
      "dist[s] = 0;",
      "pq.push({0, s});",
      "while(!pq.empty()) {",
      "  auto [d, u] = pq.top(); pq.pop();",
      "  if(d > dist[u]) continue;",
      "  for(auto [v, w] : adj[u]) {",
      "    if(dist[v] > dist[u] + w) {",
      "      dist[v] = dist[u] + w;",
      "      pq.push({dist[v], v});",
      "    }",
      "  }",
      "}"
    ],
    "description": "Dijkstra's algorithm"
  },
  "zero_one_bfs": {
    "prefix": "zero_one_bfs",
    "body": [
      "vll dist(n, INF);",
      "deque<int> dq;",
      "dist[s] = 0;",
      "dq.push_front(s);",
      "while(!dq.empty()) {",
      "  int u = dq.front(); dq.pop_front();",
      "  for(auto [v, w] : adj[u]) {",
      "    if(dist[v] > dist[u] + w) {",
      "      dist[v] = dist[u] + w;",
      "      if(w == 0) dq.push_front(v);",
      "      else dq.push_back(v);",
      "    }",
      "  }",
      "}"
    ],
    "description": "0-1 BFS"
  },
  "bellman_ford": {
    "prefix": "bellman_ford",
    "body": [
      "vll dist(n, INF);",
      "dist[s] = 0;",
      "for(int i = 0; i < n-1; ++i) {",
      "  for(auto &e : edges) {",
      "    auto [u, v, w] = e;",
      "    if(dist[u] != INF && dist[v] > dist[u] + w)",
      "      dist[v] = dist[u] + w;",
      "  }",
      "}",
      "// check negative cycles:",
      "// for(auto &e : edges) if(dist[u]!=INF && dist[v] > dist[u]+w) => cycle"
    ],
    "description": "Bellman-Ford algorithm"
  },
  "floyd": {
    "prefix": "floyd",
    "body": [
      "for(int k = 0; k < n; ++k)",
      "  for(int i = 0; i < n; ++i)",
      "    for(int j = 0; j < n; ++j)",
      "      d[i][j] = min(d[i][j], d[i][k] + d[k][j]);"
    ],
    "description": "Floyd-Warshall APSP"
  },
  "toposort": {
    "prefix": "toposort",
    "body": [
      "vi indeg(n);",
      "for(auto &v : adj) for(int u : v) indeg[u]++;",
      "queue<int> q;",
      "for(int i = 0; i < n; ++i) if(indeg[i] == 0) q.push(i);",
      "vi topo;",
      "while(!q.empty()) {",
      "  int u = q.front(); q.pop();",
      "  topo.pb(u);",
      "  for(int v : adj[u]) {",
      "    if(--indeg[v] == 0) q.push(v);",
      "  }",
      "}"
    ],
    "description": "Topological sort (Kahn's algorithm)"
  },
  "kosaraju": {
    "prefix": "kosaraju",
    "body": [
      "int n;",
      "vvi adj, radj;",
      "vb vis;",
      "vi order, comp;",
      "void dfs1(int u) {",
      "  vis[u] = true;",
      "  for(int v : adj[u]) if(!vis[v]) dfs1(v);",
      "  order.pb(u);",
      "}",
      "void dfs2(int u, int c) {",
      "  comp[u] = c;",
      "  for(int v : radj[u]) if(comp[v] == -1) dfs2(v, c);",
      "}",
      "void kosaraju() {",
      "  vis.assign(n, false);",
      "  for(int i=0; i<n; ++i) if(!vis[i]) dfs1(i);",
      "  reverse(all(order));",
      "  comp.assign(n, -1);",
      "  int c = 0;",
      "  for(int u : order) if(comp[u] == -1) dfs2(u, c++);",
      "}"
    ],
    "description": "Kosaraju's SCC"
  },
  "tarjan_scc": {
    "prefix": "tarjan_scc",
    "body": [
      "int n;",
      "vvi adj;",
      "vi idx, lowlink, comp;",
      "stack<int> st;",
      "vector<bool> onstack;",
      "int timer = 0, scc_cnt = 0;",
      "void dfs(int u) {",
      "  idx[u] = lowlink[u] = timer++;",
      "  st.push(u);",
      "  onstack[u] = true;",
      "  for(int v : adj[u]) {",
      "    if(idx[v] == -1) {",
      "      dfs(v);",
      "      lowlink[u] = min(lowlink[u], lowlink[v]);",
      "    } else if(onstack[v]) {",
      "      lowlink[u] = min(lowlink[u], idx[v]);",
      "    }",
      "  }",
      "  if(lowlink[u] == idx[u]) {",
      "    while(true) {",
      "      int w = st.top(); st.pop();",
      "      onstack[w] = false;",
      "      comp[w] = scc_cnt;",
      "      if(w == u) break;",
      "    }",
      "    ++scc_cnt;",
      "  }",
      "}",
      "void find_scc() {",
      "  idx.assign(n, -1);",
      "  lowlink.assign(n, -1);",
      "  comp.assign(n, -1);",
      "  onstack.assign(n, false);",
      "  for(int i=0; i<n; ++i) if(idx[i]==-1) dfs(i);",
      "}"
    ],
    "description": "Tarjan's strongly connected components"
  },
  "kruskal": {
    "prefix": "kruskal",
    "body": [
      "struct Edge { int u, v; ll w; };",
      "vector<Edge> edges;",
      "sort(all(edges), [](auto &a, auto &b) { return a.w < b.w; });",
      "DSU dsu(n);",
      "ll mst_cost = 0;",
      "for(auto &e : edges) {",
      "  if(dsu.unite(e.u, e.v)) {",
      "    mst_cost += e.w;",
      "  }",
      "}"
    ],
    "description": "Kruskal's MST"
  },
  "prim": {
    "prefix": "prim",
    "body": [
      "vll key(n, INF);",
      "vb inMST(n, false);",
      "priority_queue<pll, vector<pll>, greater<pll>> pq;",
      "key[0] = 0;",
      "pq.push({0, 0});",
      "while(!pq.empty()) {",
      "  auto [d, u] = pq.top(); pq.pop();",
      "  if(inMST[u]) continue;",
      "  inMST[u] = true;",
      "  for(auto [v, w] : adj[u]) {",
      "    if(!inMST[v] && key[v] > w) {",
      "      key[v] = w;",
      "      pq.push({key[v], v});",
      "    }",
      "  }",
      "}",
      "ll mst_cost = accumulate(all(key), 0LL);"
    ],
    "description": "Prim's MST"
  },
  "euler_tour": {
    "prefix": "euler_tour",
    "body": [
      "int timer = 0;",
      "vi tin(n), tout(n);",
      "function<void(int,int)> dfs = [&](int u, int p) {",
      "  tin[u] = timer++;",
      "  for(int v : adj[u]) if(v != p) dfs(v, u);",
      "  tout[u] = timer-1;",
      "};",
      "dfs(root, -1);"
    ],
    "description": "Euler tour (in/out times for subtree queries)"
  },
  "tree_diameter": {
    "prefix": "tree_diameter",
    "body": [
      "auto bfs_far = [&](int s) {",
      "  vi dist(n, -1);",
      "  queue<int> q;",
      "  dist[s] = 0; q.push(s);",
      "  int far = s;",
      "  while(!q.empty()) {",
      "    int u = q.front(); q.pop();",
      "    for(int v : adj[u]) if(dist[v]==-1) {",
      "      dist[v] = dist[u]+1;",
      "      q.push(v);",
      "      if(dist[v] > dist[far]) far = v;",
      "    }",
      "  }",
      "  return make_pair(far, dist[far]);",
      "};",
      "auto [end1, _] = bfs_far(0);",
      "auto [end2, diam] = bfs_far(end1);"
    ],
    "description": "Tree diameter (two BFS)"
  },
  "gcd": {
    "prefix": "gcd",
    "body": ["#define gcd __gcd"],
    "description": "GCD macro"
  },
  "lcm": {
    "prefix": "lcm",
    "body": ["inline ll lcm(ll a, ll b) { return a / gcd(a,b) * b; }"],
    "description": "LCM function"
  },
  "sieve": {
    "prefix": "sieve",
    "body": [
      "const int N = 1e6+5;",
      "vector<bool> is_prime(N, true);",
      "is_prime[0] = is_prime[1] = false;",
      "for(int i=2; i*i < N; ++i) {",
      "  if(is_prime[i]) {",
      "    for(int j=i*i; j < N; j+=i) is_prime[j] = false;",
      "  }",
      "}"
    ],
    "description": "Eratosthenes sieve"
  },
  "linear_sieve": {
    "prefix": "linear_sieve",
    "body": [
      "const int N = 1e6+5;",
      "vi primes;",
      "vi spf(N);",
      "for(int i=2; i<N; ++i) {",
      "  if(spf[i] == 0) {",
      "    spf[i] = i;",
      "    primes.pb(i);",
      "  }",
      "  for(auto p : primes) {",
      "    if(p > spf[i] || i*p >= N) break;",
      "    spf[i*p] = p;",
      "  }",
      "}"
    ],
    "description": "Linear sieve (SPF array)"
  },
  "prime_factorization": {
    "prefix": "prime_factorization",
    "body": [
      "vector<pll> factors;",
      "while(x > 1) {",
      "  ll p = spf[x];",
      "  ll cnt = 0;",
      "  while(x % p == 0) {",
      "    x /= p;",
      "    ++cnt;",
      "  }",
      "  factors.eb(p, cnt);",
      "}"
    ],
    "description": "Prime factorization using SPF"
  },
  "modpow": {
    "prefix": "modpow",
    "body": [
      "ll modpow(ll a, ll e, ll mod) {",
      "  ll res = 1;",
      "  while(e) {",
      "    if(e & 1) res = res * a % mod;",
      "    a = a * a % mod;",
      "    e >>= 1;",
      "  }",
      "  return res;",
      "}"
    ],
    "description": "Modular exponentiation"
  },
  "modinv": {
    "prefix": "modinv",
    "body": ["ll modinv(ll a, ll mod) { return modpow(a, mod-2, mod); }"],
    "description": "Modular inverse (mod prime)"
  },
  "nCr_mod": {
    "prefix": "nCr_mod",
    "body": [
      "struct Combinatorics {",
      "  vector<ll> fact, invfact;",
      "  ll mod;",
      "  Combinatorics(int n, ll mod) : mod(mod) {",
      "    fact.resize(n+1);",
      "    invfact.resize(n+1);",
      "    fact[0] = 1;",
      "    for(int i=1; i<=n; ++i) fact[i] = fact[i-1] * i % mod;",
      "    invfact[n] = modinv(fact[n], mod);",
      "    for(int i=n-1; i>=0; --i) invfact[i] = invfact[i+1] * (i+1) % mod;",
      "  }",
      "  ll nCr(int n, int r) {",
      "    if(r < 0 || r > n) return 0;",
      "    return fact[n] * invfact[r] % mod * invfact[n-r] % mod;",
      "  }",
      "};"
    ],
    "description": "Combinations modulo prime"
  },
  "euler_totient": {
    "prefix": "euler_totient",
    "body": [
      "ll phi(ll n) {",
      "  ll res = n;",
      "  for(ll p=2; p*p <= n; ++p) {",
      "    if(n % p == 0) {",
      "      while(n % p == 0) n /= p;",
      "      res -= res / p;",
      "    }",
      "  }",
      "  if(n > 1) res -= res / n;",
      "  return res;",
      "}"
    ],
    "description": "Euler's totient function"
  },
  "memo_dp": {
    "prefix": "memo_dp",
    "body": [
      "vector<vll> memo(n, vll(m, -1));",
      "function<ll(int,int)> dp = [&](int i, int j) -> ll {",
      "  if(i == n) return 0;",
      "  if(memo[i][j] != -1) return memo[i][j];",
      "  ll &ans = memo[i][j];",
      "  ans = 0;",
      "  // transitions",
      "  return ans;",
      "};"
    ],
    "description": "Memoization DP template"
  },
  "tab_dp": {
    "prefix": "tab_dp",
    "body": [
      "vvi dp(n+1, vi(m+1, 0));",
      "for(int i = n-1; i >= 0; --i) {",
      "  for(int j = m-1; j >= 0; --j) {",
      "    dp[i][j] = max(dp[i+1][j], dp[i][j+1]); // example",
      "  }",
      "}"
    ],
    "description": "Tabulation DP template"
  },
  "digit_dp": {
    "prefix": "digit_dp",
    "body": [
      "string num;",
      "ll dp[20][2][2];",
      "ll digit_dp(int pos, bool tight, bool started) {",
      "  if(pos == sz(num)) return 1;",
      "  ll &ans = dp[pos][tight][started];",
      "  if(ans != -1) return ans;",
      "  ans = 0;",
      "  int limit = tight ? num[pos]-'0' : 9;",
      "  for(int d=0; d<=limit; ++d) {",
      "    ans += digit_dp(pos+1, tight && (d==limit), started || (d!=0));",
      "  }",
      "  return ans;",
      "}"
    ],
    "description": "Digit DP skeleton"
  },
  "bitmask_dp": {
    "prefix": "bitmask_dp",
    "body": [
      "vi dp(1<<n, INF);",
      "dp[0] = 0;",
      "for(int mask = 0; mask < (1<<n); ++mask) {",
      "  for(int i = 0; i < n; ++i) {",
      "    if(mask & (1<<i)) {",
      "      int prev = mask ^ (1<<i);",
      "      dp[mask] = min(dp[mask], dp[prev] + cost[i][__builtin_popcount(mask)-1]);",
      "    }",
      "  }",
      "}"
    ],
    "description": "Bitmask DP (assignment problem style)"
  },
  "kmp": {
    "prefix": "kmp",
    "body": [
      "vi prefix_function(const string &s) {",
      "  int n = sz(s);",
      "  vi pi(n);",
      "  for(int i=1; i<n; ++i) {",
      "    int j = pi[i-1];",
      "    while(j > 0 && s[i] != s[j]) j = pi[j-1];",
      "    if(s[i] == s[j]) ++j;",
      "    pi[i] = j;",
      "  }",
      "  return pi;",
      "}"
    ],
    "description": "KMP prefix function"
  },
  "z_function": {
    "prefix": "z_function",
    "body": [
      "vi z_function(const string &s) {",
      "  int n = sz(s);",
      "  vi z(n);",
      "  int l = 0, r = 0;",
      "  for(int i=1; i<n; ++i) {",
      "    if(i <= r) z[i] = min(r-i+1, z[i-l]);",
      "    while(i+z[i] < n && s[z[i]] == s[i+z[i]]) ++z[i];",
      "    if(i+z[i]-1 > r) {",
      "      l = i;",
      "      r = i+z[i]-1;",
      "    }",
      "  }",
      "  return z;",
      "}"
    ],
    "description": "Z algorithm"
  },
  "rabin_karp": {
    "prefix": "rabin_karp",
    "body": [
      "struct RollingHash {",
      "  ll mod, p;",
      "  vector<ll> h, pw;",
      "  RollingHash(const string &s, ll mod=1e9+7, ll p=31) : mod(mod), p(p) {",
      "    int n = sz(s);",
      "    h.resize(n+1);",
      "    pw.resize(n+1, 1);",
      "    for(int i=0; i<n; ++i) {",
      "      h[i+1] = (h[i]*p + s[i]) % mod;",
      "      pw[i+1] = pw[i]*p % mod;",
      "    }",
      "  }",
      "  ll hash(int l, int r) {",
      "    return (h[r+1] - h[l]*pw[r-l+1] % mod + mod) % mod;",
      "  }",
      "};"
    ],
    "description": "Rolling hash (Rabin-Karp)"
  },
  "manacher": {
    "prefix": "manacher",
    "body": [
      "pair<vi,vi> manacher(const string &s) {",
      "  int n = sz(s);",
      "  vi d1(n), d2(n);",
      "  for(int i=0, l=0, r=-1; i<n; ++i) {",
      "    int k = (i>r) ? 1 : min(d1[l+r-i], r-i+1);",
      "    while(i-k>=0 && i+k<n && s[i-k]==s[i+k]) ++k;",
      "    d1[i] = k--;",
      "    if(i+k > r) { l = i-k; r = i+k; }",
      "  }",
      "  for(int i=0, l=0, r=-1; i<n; ++i) {",
      "    int k = (i>r) ? 0 : min(d2[l+r-i+1], r-i+1);",
      "    while(i-k-1>=0 && i+k<n && s[i-k-1]==s[i+k]) ++k;",
      "    d2[i] = k--;",
      "    if(i+k > r) { l = i-k-1; r = i+k; }",
      "  }",
      "  return {d1, d2};",
      "}"
    ],
    "description": "Manacher's algorithm (palindromic radii)"
  },
  "point": {
    "prefix": "point",
    "body": ["struct Point { ll x, y; };"],
    "description": "2D point"
  },
  "dist_sq": {
    "prefix": "dist_sq",
    "body": ["ll dist_sq(Point a, Point b) { return (a.x-b.x)*(a.x-b.x) + (a.y-b.y)*(a.y-b.y); }"],
    "description": "squared distance"
  },
  "cross": {
    "prefix": "cross",
    "body": ["ll cross(Point a, Point b, Point c) { return (b.x-a.x)*(c.y-a.y) - (b.y-a.y)*(c.x-a.x); }"],
    "description": "cross product (a->b, a->c)"
  },
  "orientation": {
    "prefix": "orientation",
    "body": ["int orient(Point a, Point b, Point c) { ll val = cross(a,b,c); if(val==0) return 0; return val>0 ? 1 : 2; } // 1=CCW,2=CW"],
    "description": "orientation test"
  },
  "convex_hull": {
    "prefix": "convex_hull",
    "body": [
      "vector<Point> convex_hull(vector<Point> pts) {",
      "  sort(all(pts), [](Point a, Point b) { return tie(a.x,a.y) < tie(b.x,b.y); });",
      "  vector<Point> hull;",
      "  for(int step=0; step<2; ++step) {",
      "    auto start = sz(hull);",
      "    for(auto p : pts) {",
      "      while(sz(hull)-start >= 2 && cross(hull[sz(hull)-2], hull.back(), p) <= 0)",
      "        hull.pop_back();",
      "      hull.pb(p);",
      "    }",
      "    hull.pop_back();",
      "    reverse(all(pts));",
      "  }",
      "  return hull;",
      "}"
    ],
    "description": "Convex hull (Monotone chain)"
  },
  "mo": {
    "prefix": "mo",
    "body": [
      "struct Mo {",
      "  int block;",
      "  struct Query { int l, r, idx; };",
      "  vector<Query> queries;",
      "  Mo(int n) { block = sqrt(n); }",
      "  void add_query(int l, int r, int idx) { queries.pb({l, r, idx}); }",
      "  void run(vector<ll> &ans) {",
      "    sort(all(queries), [&](const Query &a, const Query &b) {",
      "      if(a.l/block != b.l/block) return a.l < b.l;",
      "      return (a.l/block % 2) ? (a.r > b.r) : (a.r < b.r);",
      "    });",
      "    int L = 0, R = -1;",
      "    // current state",
      "    for(auto &q : queries) {",
      "      while(L > q.l) add(--L);",
      "      while(R < q.r) add(++R);",
      "      while(L < q.l) remove(L++);",
      "      while(R > q.r) remove(R--);",
      "      ans[q.idx] = /* current answer */;",
      "    }",
      "  }",
      "  void add(int pos) { }",
      "  void remove(int pos) { }",
      "};"
    ],
    "description": "Mo's algorithm skeleton"
  },
  "hld": {
    "prefix": "hld",
    "body": [
      "struct HLD {",
      "  vi parent, depth, heavy, head, pos;",
      "  int cur_pos;",
      "  HLD(const vvi &adj, int root) {",
      "    int n = sz(adj);",
      "    parent.resize(n);",
      "    depth.resize(n);",
      "    heavy.assign(n, -1);",
      "    head.resize(n);",
      "    pos.resize(n);",
      "    cur_pos = 0;",
      "    function<int(int,int)> dfs = [&](int u, int p) {",
      "      int sz = 1, max_sz = 0;",
      "      parent[u] = p;",
      "      for(int v : adj[u]) if(v != p) {",
      "        depth[v] = depth[u] + 1;",
      "        int sub = dfs(v, u);",
      "        sz += sub;",
      "        if(sub > max_sz) { max_sz = sub; heavy[u] = v; }",
      "      }",
      "      return sz;",
      "    };",
      "    dfs(root, -1);",
      "    function<void(int,int)> decompose = [&](int u, int h) {",
      "      head[u] = h;",
      "      pos[u] = cur_pos++;",
      "      if(heavy[u] != -1) decompose(heavy[u], h);",
      "      for(int v : adj[u]) if(v != parent[u] && v != heavy[u])",
      "        decompose(v, v);",
      "    };",
      "    decompose(root, root);",
      "  }",
      "  // path query stubs",
      "};"
    ],
    "description": "Heavy-Light Decomposition"
  },
  "centroid": {
    "prefix": "centroid",
    "body": [
      "struct CentroidDecomp {",
      "  vvi adj;",
      "  vb dead;",
      "  vi sz;",
      "  CentroidDecomp(const vvi &g) : adj(g), dead(sz(g)), sz(sz(g)) {}",
      "  int get_size(int u, int p) {",
      "    sz[u] = 1;",
      "    for(int v : adj[u]) if(v != p && !dead[v])",
      "      sz[u] += get_size(v, u);",
      "    return sz[u];",
      "  }",
      "  int get_centroid(int u, int p, int n) {",
      "    for(int v : adj[u]) if(v != p && !dead[v] && sz[v] > n/2)",
      "      return get_centroid(v, u, n);",
      "    return u;",
      "  }",
      "  void decompose(int u) {",
      "    int n = get_size(u, -1);",
      "    int c = get_centroid(u, -1, n);",
      "    dead[c] = true;",
      "    // process centroid c",
      "    for(int v : adj[c]) if(!dead[v]) decompose(v);",
      "  }",
      "};"
    ],
    "description": "Centroid decomposition"
  },
  "matrix_exp": {
    "prefix": "matrix_exp",
    "body": [
      "struct Matrix {",
      "  vvll mat;",
      "  int n;",
      "  Matrix(int n) : n(n), mat(n, vll(n)) {}",
      "  Matrix operator*(const Matrix &other) const {",
      "    Matrix res(n);",
      "    for(int i=0; i<n; ++i)",
      "      for(int k=0; k<n; ++k)",
      "        for(int j=0; j<n; ++j)",
      "          res.mat[i][j] = (res.mat[i][j] + mat[i][k]*other.mat[k][j]) % MOD;",
      "    return res;",
      "  }",
      "  Matrix power(ll e) const {",
      "    Matrix res(n), b = *this;",
      "    for(int i=0; i<n; ++i) res.mat[i][i] = 1;",
      "    while(e) {",
      "      if(e&1) res = res * b;",
      "      b = b * b;",
      "      e >>= 1;",
      "    }",
      "    return res;",
      "  }",
      "};"
    ],
    "description": "Matrix exponentiation"
  },
  "fft": {
    "prefix": "fft",
    "body": [
      "using cd = complex<double>;",
      "const double PI = acos(-1);",
      "void fft(vector<cd> &a, bool invert) {",
      "  int n = sz(a);",
      "  for(int i=1, j=0; i<n; ++i) {",
      "    int bit = n>>1;",
      "    for(; j&bit; bit>>=1) j ^= bit;",
      "    j ^= bit;",
      "    if(i < j) swap(a[i], a[j]);",
      "  }",
      "  for(int len=2; len<=n; len<<=1) {",
      "    double ang = 2*PI/len * (invert ? -1 : 1);",
      "    cd wlen(cos(ang), sin(ang));",
      "    for(int i=0; i<n; i+=len) {",
      "      cd w(1);",
      "      for(int j=0; j<len/2; ++j) {",
      "        cd u = a[i+j], v = a[i+j+len/2] * w;",
      "        a[i+j] = u + v;",
      "        a[i+j+len/2] = u - v;",
      "        w *= wlen;",
      "      }",
      "    }",
      "  }",
      "  if(invert) for(auto &x : a) x /= n;",
      "}"
    ],
    "description": "Fast Fourier Transform"
  },
  "ntt": {
    "prefix": "ntt",
    "body": [
      "const ll MOD = 998244353, ROOT = 3;",
      "void ntt(vll &a, bool invert) {",
      "  int n = sz(a);",
      "  for(int i=1, j=0; i<n; ++i) {",
      "    int bit = n>>1;",
      "    for(; j&bit; bit>>=1) j ^= bit;",
      "    j ^= bit;",
      "    if(i < j) swap(a[i], a[j]);",
      "  }",
      "  for(int len=2; len<=n; len<<=1) {",
      "    ll wlen = modpow(ROOT, (MOD-1)/len, MOD);",
      "    if(invert) wlen = modinv(wlen, MOD);",
      "    for(int i=0; i<n; i+=len) {",
      "      ll w = 1;",
      "      for(int j=0; j<len/2; ++j) {",
      "        ll u = a[i+j], v = a[i+j+len/2] * w % MOD;",
      "        a[i+j] = (u+v) % MOD;",
      "        a[i+j+len/2] = (u-v+MOD) % MOD;",
      "        w = w * wlen % MOD;",
      "      }",
      "    }",
      "  }",
      "  if(invert) {",
      "    ll inv_n = modinv(n, MOD);",
      "    for(auto &x : a) x = x * inv_n % MOD;",
      "  }",
      "}"
    ],
    "description": "Number Theoretic Transform"
  },
