  "dsu": {
    "prefix": "dsu",
    "body": [
      "struct DSU {",
      "  vi parent, rank;",
      "  DSU(int n) : parent(n), rank(n,0) {",
      "    iota(all(parent), 0);",
      "  }",
      "  int find(int x) {",
      "    return parent[x] == x ? x : parent[x] = find(parent[x]);",
      "  }",
      "  bool unite(int x, int y) {",
      "    x = find(x);",
      "    y = find(y);",
      "    if(x == y) return false;",
      "    if(rank[x] < rank[y]) swap(x,y);",
      "    parent[y] = x;",
      "    if(rank[x] == rank[y]) ++rank[x];",
      "    return true;",
      "  }",
      "};"
    ],
    "description": "Disjoint Set Union (Union-Find)"
  },
  "fenwick": {
    "prefix": "fenwick",
    "body": [
      "struct Fenwick {",
      "  vll bit;",
      "  Fenwick(int n) : bit(n+1) {}",
      "  void add(int i, ll val) {",
      "    for(; i < sz(bit); i += i & -i) bit[i] += val;",
      "  }",
      "  ll sum(int i) {",
      "    ll s = 0;",
      "    for(; i > 0; i -= i & -i) s += bit[i];",
      "    return s;",
      "  }",
      "  ll query(int l, int r) { return sum(r) - sum(l-1); }",
      "};"
    ],
    "description": "Fenwick Tree (Binary Indexed Tree)"
  },
  "segtree": {
    "prefix": "segtree",
    "body": [
      "struct SegTree {",
      "  int n;",
      "  vll tree;",
      "  SegTree(int n) : n(n), tree(2*n) {}",
      "  void build() {",
      "    for(int i = n-1; i > 0; --i)",
      "      tree[i] = tree[i<<1] + tree[i<<1|1];",
      "  }",
      "  void update(int p, ll val) {",
      "    for(tree[p += n] = val; p > 1; p >>= 1)",
      "      tree[p>>1] = tree[p] + tree[p^1];",
      "  }",
      "  ll query(int l, int r) {",
      "    ll res = 0;",
      "    for(l += n, r += n+1; l < r; l >>= 1, r >>= 1) {",
      "      if(l&1) res += tree[l++];",
      "      if(r&1) res += tree[--r];",
      "    }",
      "    return res;",
      "  }",
      "};"
    ],
    "description": "Segment Tree (point update, range sum)"
  },
  "lazy_segtree": {
    "prefix": "lazy_segtree",
    "body": [
      "struct LazySegTree {",
      "  int n;",
      "  vll tree, lazy;",
      "  LazySegTree(int n) : n(n), tree(4*n), lazy(4*n) {}",
      "  void push(int v, int tl, int tr) {",
      "    if(lazy[v]) {",
      "      int tm = (tl+tr)/2;",
      "      tree[v*2] += lazy[v] * (tm-tl+1);",
      "      lazy[v*2] += lazy[v];",
      "      tree[v*2+1] += lazy[v] * (tr-tm);",
      "      lazy[v*2+1] += lazy[v];",
      "      lazy[v] = 0;",
      "    }",
      "  }",
      "  void update(int v, int tl, int tr, int l, int r, ll add) {",
      "    if(l > r) return;",
      "    if(l == tl && r == tr) {",
      "      tree[v] += add * (r-l+1);",
      "      lazy[v] += add;",
      "      return;",
      "    }",
      "    push(v, tl, tr);",
      "    int tm = (tl+tr)/2;",
      "    update(v*2, tl, tm, l, min(r,tm), add);",
      "    update(v*2+1, tm+1, tr, max(l,tm+1), r, add);",
      "    tree[v] = tree[v*2] + tree[v*2+1];",
      "  }",
      "  ll query(int v, int tl, int tr, int l, int r) {",
      "    if(l > r) return 0;",
      "    if(l == tl && r == tr) return tree[v];",
      "    push(v, tl, tr);",
      "    int tm = (tl+tr)/2;",
      "    return query(v*2, tl, tm, l, min(r,tm)) +",
      "           query(v*2+1, tm+1, tr, max(l,tm+1), r);",
      "  }",
      "};"
    ],
    "description": "Lazy Segment Tree (range add, range sum)"
  },
  "sparse_table": {
    "prefix": "sparse_table",
    "body": [
      "struct SparseTable {",
      "  vvi st;",
      "  vi log;",
      "  SparseTable(const vi &a) {",
      "    int n = sz(a);",
      "    log.resize(n+1);",
      "    for(int i=2; i<=n; ++i) log[i] = log[i/2]+1;",
      "    int K = log[n]+1;",
      "    st.assign(K, vi(n));",
      "    st[0] = a;",
      "    for(int j=1; j<K; ++j) {",
      "      for(int i=0; i+(1<<j)<=n; ++i) {",
      "        st[j][i] = min(st[j-1][i], st[j-1][i+(1<<(j-1))]);",
      "      }",
      "    }",
      "  }",
      "  int query(int l, int r) {",
      "    int j = log[r-l+1];",
      "    return min(st[j][l], st[j][r-(1<<j)+1]);",
      "  }",
      "};"
    ],
    "description": "Sparse Table for RMQ"
  },
  "trie": {
    "prefix": "trie",
    "body": [
      "struct TrieNode {",
      "  int next[26];",
      "  bool is_end;",
      "  TrieNode() {",
      "    memset(next, -1, sizeof(next));",
      "    is_end = false;",
      "  }",
      "};",
      "struct Trie {",
      "  vector<TrieNode> nodes;",
      "  Trie() { nodes.emplace_back(); }",
      "  void insert(const string &s) {",
      "    int v = 0;",
      "    for(char c : s) {",
      "      int idx = c - 'a';",
      "      if(nodes[v].next[idx] == -1) {",
      "        nodes[v].next[idx] = sz(nodes);",
      "        nodes.emplace_back();",
      "      }",
      "      v = nodes[v].next[idx];",
      "    }",
      "    nodes[v].is_end = true;",
      "  }",
      "  bool search(const string &s) {",
      "    int v = 0;",
      "    for(char c : s) {",
      "      int idx = c - 'a';",
      "      if(nodes[v].next[idx] == -1) return false;",
      "      v = nodes[v].next[idx];",
      "    }",
      "    return nodes[v].is_end;",
      "  }",
      "};"
    ],
    "description": "Trie for lowercase strings"
  },
