<file path="nexel-ide/src/components/Explorer.css">
/* --- COLLAPSIBLE SIDEBAR CONTAINER (Standard solid collapse) --- */
.nx-sidebar-container {
  width: 260px;
  min-width: 260px;
  height: 100vh;
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), 
              opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1), 
              width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  overflow: hidden;
}

.nx-sidebar-container.collapsed {
  width: 0px !important;
  min-width: 0px !important;
  transform: translateX(-260px);
  opacity: 0;
  pointer-events: none;
}

/* --- COLLAPSIBLE NAVDOCK CONTAINER (Hover reveal pop-out) --- */
.nx-navdock-wrapper-container {
  transform: translateX(0);
  opacity: 1;
}

.nx-navdock-wrapper-container.collapsed {
  transform: translateX(-80px);
  opacity: 0;
  pointer-events: none;
}

.nx-navdock-wrapper-container.collapsed.hover-revealed {
  transform: translateX(0);
  opacity: 1;
  pointer-events: auto;
  box-shadow: 8px 0 24px rgba(0, 0, 0, 0.5);
}

/* --- PREMIUM MINIMAL MONOCHROME WORKSPACE EXPLORER --- */
.nx-explorer-wrapper {
  width: 260px;
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  user-select: none;
  background: #0B0B0D;
  border-right: 1px solid rgba(255, 255, 255, 0.03);
  padding-left: 72px;
  z-index: 10;
}

/* Header Text Track with Action Buttons Row */
.nx-explorer-header {
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 12px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.02);
}

.nx-explorer-title {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: rgba(255, 255, 255, 0.35);
  cursor: pointer;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100px;
  transition: color 0.15s ease;
}

.nx-explorer-title:hover {
  color: #ffffff;
}

/* Tool belt container matching your photo query reference */
.nx-action-bar {
  display: flex;
  align-items: center;
  gap: 2px;
}

.nx-action-btn {
  background: transparent;
  border: none;
  padding: 4px;
  margin: 0;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.25);
  border-radius: 4px;
  transition: color 0.15s ease, background-color 0.15s ease;
}

.nx-action-btn:hover:not(:disabled) {
  color: #ffffff;
  background-color: rgba(255, 255, 255, 0.04);
}

.nx-action-btn:disabled {
  opacity: 0.15;
