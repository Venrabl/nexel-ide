/* Central alignment axis - elegant & minimal left alignment */
.nd-wrapper-axis {
  position: fixed;
  left: 16px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  justify-content: center;
  align-items: center;
  width: 56px;
  z-index: 9999;
  background: transparent;
  box-sizing: border-box;
}

/* --- DOCK CONTAINER (Minimalist Monochrome Premium Glass) --- */
.nd-dock {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  width: 48px;
  height: 360px;
  padding: 16px 0;
  border-radius: 16px;
  box-sizing: border-box;
  
  background: rgba(15, 15, 17, 0.75);
  border: 1px solid rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  
  box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Minimalist border highlight on hover, no size expand for maximum simplicity */
.nd-dock-expanded {
  background: rgba(10, 10, 12, 0.85);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: 0 20px 48px rgba(0, 0, 0, 0.5);
}

/* Stack layout for item positions */
.nd-items-stack {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24px;
  width: 100%;
}

.nd-item-row {
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  width: 100%;
  cursor: pointer;
}

/* Capsule framing */
.nd-capsule-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
}

.nd-icon-fluid {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  border-radius: 8px; /* Clean minimalist squircle */
  color: rgba(255, 255, 255, 0.35);
  background: transparent;
  border: 1px solid transparent;
  z-index: 2;
  box-sizing: border-box;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.nd-icon {
  width: 16px;
  height: 16px;
  transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

/* --- STATE 3: ITEM HOVER (Minimalist B&W feedback) --- */
.nd-row-hovered .nd-icon-fluid {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.08);
}

.nd-row-hovered .nd-icon {
  transform: scale(1.05);
}

/* --- PREMIUM MINIMAL TOOLTIPS --- */
.nd-tooltip {
  position: absolute;
  left: calc(100% + 16px);
  top: 50%;
  transform: translateY(-50%) scale(0.96);
  background: #0d0d0f;
  border: 1px solid rgba(255, 255, 255, 0.08);
  padding: 6px 10px;
  border-radius: 6px;
  opacity: 0;
  pointer-events: none;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.5);
  transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.nd-tooltip-text {
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  color: rgba(255, 255, 255, 0.85);
  font-size: 11px;
  font-weight: 500;
  white-space: nowrap;
  letter-spacing: 0.02em;
}

.nd-row-hovered .nd-tooltip {
  opacity: 1;
  transform: translateY(-50%) scale(1);
}

/* Decorative hardware pins */
.nd-hardware-pin {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 10px;
}

.nd-dot {
  width: 3px;
  height: 3px;
  border-radius: 50%;
